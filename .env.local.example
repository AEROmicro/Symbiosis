# Symbiosis – Environment Variables
# Copy this file to .env.local and fill in your values.

# ── Supabase (required for account system & cloud portfolio sync) ─────────────
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase Auth Redirect URL ────────────────────────────────────────────────
# In your Supabase project go to Authentication > URL Configuration and add:
#   http://localhost:3000/api/auth/callback   (for local development)
#   https://your-domain.com/api/auth/callback (for production)

# ── Notes ─────────────────────────────────────────────────────────────────────
# The app works without these variables – it falls back to localStorage-only
# storage when Supabase is not configured.
#
# Alpaca API keys are entered by the user in the UI and stored in their browser.
# They are never stored on the server.
